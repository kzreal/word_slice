# LLM API Configuration
# Copy this file to .env and fill in your API details

# Custom LLM API endpoint URL
# Example: https://api.example.com/v1/analyze-image
LLM_API_ENDPOINT=

# API key for authentication
LLM_API_KEY=

# Model name (optional)
LLM_MODEL=vision-model

# Request timeout in seconds (optional)
LLM_TIMEOUT=30

# Maximum retry attempts (optional)
LLM_MAX_RETRIES=3